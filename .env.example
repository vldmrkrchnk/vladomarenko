# Copy to .env.local for local dev, or .env for production.
# Never commit a filled-in .env or .env.local — both are gitignored.

# ── Required ────────────────────────────────────────────────

# Telegram bot token from @BotFather.
# For LOCAL DEV: create your own test bot via /newbot in BotFather and paste its token here.
# For PRODUCTION: the live Krapral bot token (stored in Fly secrets, not in this file).
TELEGRAM_TOKEN=

# xAI Grok API key from https://console.x.ai/
GROK_API_KEY=

# OpenAI API key (used only for Whisper voice transcription).
# Required. Grab one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Optional ────────────────────────────────────────────────

# Set to "dev" to disable file/GCS log writes and use console-only logging.
# Recommended for local development.
BOT_MODE=dev

# Set to "production" for JSON-formatted logs (what Fly / Cloud Logging expect).
# Leave unset locally so pino-pretty gives you readable logs.
# NODE_ENV=production

# Public HTTPS URL for webhook mode. If unset, bot falls back to long-polling.
# Local dev: leave unset — polling is simpler and doesn't need a public URL.
# Production: Fly sets this as a secret to https://krapral-bot.fly.dev
# WEBHOOK_URL=

# Optional GCS bucket for persisting request/response logs (prod only).
# GCP_STORAGE_BUCKET=
